# Live trading credentials for live_runner.py — COPY this file to `.env` and fill in.
# `.env` is git-ignored; NEVER commit real keys. Use a DEDICATED EOA, not your main
# wallet, and only fund it with USDC you are willing to risk.

# The EOA private key (L1 signer). Plain EOA only — signature_type=0.
# Do NOT use an email/website Polymarket proxy wallet (signature_type=3 fails).
POLY_PRIVATE_KEY=0xYOUR_PRIVATE_KEY

# The funder address = usually the SAME EOA address that holds the USDC.
POLY_FUNDER=0xYOUR_EOA_ADDRESS

# Optional (later): a Polymarket "builder" code for fee attribution/rewards.
# Not required to trade; live_runner does not use it yet.
# POLY_BUILDER_CODE=
